#!/usr/bin/env python3
import os
import re
import shlex
import shutil
import subprocess
from datetime import datetime
from pathlib import Path


APP = "NMAPZ"
VERSION = "0.2.0"
DEFAULT_OUTDIR = "nmapz_results"


def clear():
    os.system("cls" if os.name == "nt" else "clear")


def banner():
    print(r"""
 _   _ __  __    _    ____  ____
| \ | |  \/  |  / \  |  _ \|__  /
|  \| | |\/| | / _ \ | |_) | / /
| |\  | |  | |/ ___ \|  __/ / /_
|_| \_|_|  |_/_/   \_\_|   /____|
""")

    print(f"Guided Nmap Harness v{VERSION}")
    print("Use only on systems or networks you own or have permission to test.")
    print("-" * 70)


def pause():
    input("\nPress Enter to continue...")


def ask(prompt, default=None):
    if default is None:
        return input(f"{prompt}: ").strip()

    val = input(f"{prompt} [{default}]: ").strip()
    return val if val else str(default)


def ask_yes_no(prompt, default="n"):
    default = default.lower()
    suffix = "[Y/n]" if default == "y" else "[y/N]"

    while True:
        val = input(f"{prompt} {suffix}: ").strip().lower()

        if not val:
            return default == "y"

        if val in ("y", "yes"):
            return True

        if val in ("n", "no"):
            return False

        print("Enter y or n.")


def ask_choice(prompt, choices, default=None):
    valid = set(choices.keys())

    while True:
        print(f"\n{prompt}")
        for key, desc in choices.items():
            marker = "* " if default and key == default else "  "
            print(f"{marker}{key}) {desc}")

        val = input("\nSelect: ").strip().lower()

        if not val and default:
            return default

        if val in valid:
            return val

        print("Invalid choice. Pick one of the listed options.")


def safe_filename(text):
    text = re.sub(r"[^a-zA-Z0-9_.-]+", "_", text)
    return text.strip("_")[:80] or "scan"


def require_nmap():
    if shutil.which("nmap") is None:
        print("[!] nmap was not found in PATH.")
        print("\nInstall it first:")
        print("  sudo apt install nmap")
        raise SystemExit(1)


def warn_if_not_root(scan_flags):
    needs_root = ["-sU", "-sS"]
    if any(flag in scan_flags for flag in needs_root) and os.name != "nt":
        if hasattr(os, "geteuid") and os.geteuid() != 0:
            print("\n[!] Note: This scan may work better with sudo.")
            print("    UDP scans and SYN scans can be limited without root privileges.")


def build_target():
    clear()
    banner()
    print("Target Setup")
    print("\nChoose what you want Nmap to scan.")
    print("Examples:")
    print("  Single host:     192.168.1.10")
    print("  Subnet:          192.168.1.0/24")
    print("  Range:           192.168.1.1-50")
    print("  Host file:       targets.txt")

    mode = ask_choice(
        "Target input mode",
        {
            "1": "Single IP or hostname",
            "2": "CIDR subnet, example: 10.10.10.0/24",
            "3": "IP range, example: 10.10.10.1-50",
            "4": "Multiple targets, space-separated",
            "5": "Load targets from a file using -iL",
            "6": "Manual raw target string",
        },
        default="1",
    )

    if mode == "1":
        return ask("Target IP / hostname")

    if mode == "2":
        return ask("CIDR target")

    if mode == "3":
        return ask("IP range")

    if mode == "4":
        return ask("Targets")

    if mode == "5":
        path = ask("Target file path")
        return f"-iL {shlex.quote(path)}"

    return ask("Raw nmap target string")


def build_scan_profile():
    clear()
    banner()
    print("Scan Profile")
    print("\nPick the scan style. Safer/faster scans are listed first.")
    print("Heavier modes can be noisy, slow, or trigger alerts.")

    profile = ask_choice(
        "Choose scan mode",
        {
            "1": "Fast scan — checks common ports only",
            "2": "Service scan — default scripts + version detection",
            "3": "Full TCP port sweep — checks all 65535 TCP ports",
            "4": "Full TCP + services — all ports plus version detection",
            "5": "Aggressive scan — OS guess, scripts, traceroute, versions",
            "6": "UDP top ports — slower; best with sudo",
            "7": "Vuln script scan — noisy; uses Nmap vuln NSE scripts",
            "8": "Custom flags — type your own Nmap options",
        },
        default="2",
    )

    profiles = {
        "1": "-T4 -F",
        "2": "-T4 -sC -sV",
        "3": "-T4 -p-",
        "4": "-T4 -p- -sV",
        "5": "-T4 -A",
        "6": "-sU --top-ports 100",
        "7": "-T4 -sV --script vuln",
    }

    warnings = {
        "3": "Full TCP scans can take a while, especially against multiple hosts.",
        "4": "Full TCP + service detection can be slow and noisy.",
        "5": "Aggressive scans are noisy and may trigger security tools.",
        "6": "UDP scans are slow and usually work better with sudo.",
        "7": "Vuln script scans are noisy and should only be used with permission.",
    }

    if profile in warnings:
        print(f"\n[!] {warnings[profile]}")
        if not ask_yes_no("Continue with this scan profile?", default="y"):
            return build_scan_profile()

    if profile == "8":
        return ask("Enter custom nmap flags")

    return profiles[profile]


def build_options():
    clear()
    banner()
    print("Extra Options")
    print("\nThese adjust how Nmap behaves during the scan.")

    options = []

    if ask_yes_no("Treat hosts as online? Adds -Pn. Useful when ping is blocked", default="y"):
        options.append("-Pn")

    if ask_yes_no("Show only open ports? Adds --open. Cleaner output", default="y"):
        options.append("--open")

    verbosity = ask_choice(
        "Output detail level",
        {
            "0": "Normal output",
            "1": "Verbose -v",
            "2": "More verbose -vv",
            "3": "Very verbose -vvv",
        },
        default="1",
    )

    if verbosity != "0":
        options.append("-" + ("v" * int(verbosity)))

    if ask_yes_no("Disable DNS lookups? Adds -n. Faster and less noisy", default="n"):
        options.append("-n")

    if ask_yes_no("Show why Nmap reached each conclusion? Adds --reason", default="y"):
        options.append("--reason")

    if ask_yes_no("Exclude any hosts from the scan?", default="n"):
        exclude = ask("Exclude list, comma-separated. Example: 192.168.1.1,192.168.1.20")
        if exclude:
            options.append(f"--exclude {shlex.quote(exclude)}")

    return " ".join(options)


def build_save_options(target):
    clear()
    banner()
    print("Save Results")
    print("\nSaving is recommended so you can review results later.")

    save = ask_yes_no("Save scan results?", default="y")
    if not save:
        return ""

    outdir = Path(ask("Output folder", DEFAULT_OUTDIR))
    outdir.mkdir(parents=True, exist_ok=True)

    stamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    base = safe_filename(target.replace("-iL", "targetfile"))
    basename = outdir / f"{base}_{stamp}"

    mode = ask_choice(
        "Save format",
        {
            "1": "Normal text only: easy to read",
            "2": "All formats: normal, grepable, and XML",
            "3": "Grepable only: useful for quick parsing",
            "4": "XML only: useful for tools and reports",
        },
        default="2",
    )

    if mode == "1":
        return f"-oN {shlex.quote(str(basename) + '.txt')}"
    if mode == "2":
        return f"-oA {shlex.quote(str(basename))}"
    if mode == "3":
        return f"-oG {shlex.quote(str(basename) + '.gnmap')}"
    return f"-oX {shlex.quote(str(basename) + '.xml')}"


def assemble_command():
    target = build_target()
    profile = build_scan_profile()
    options = build_options()
    save_opts = build_save_options(target)

    parts = ["nmap", profile, options, save_opts, target]
    cmd = " ".join(part for part in parts if part.strip())
    return cmd


def confirm_command(cmd):
    while True:
        clear()
        banner()
        print("Confirm Command")
        print("\nReview the exact command before running:\n")
        print(cmd)
        print("\nOptions:")
        print("1) Run scan now")
        print("2) Print command only / dry run")
        print("3) Cancel")

        choice = input("\nSelect: ").strip().lower()

        if choice == "1":
            return "run"
        if choice == "2":
            return "print"
        if choice == "3" or choice == "q":
            return "cancel"

        print("Invalid choice.")
        pause()


def run_command(cmd):
    clear()
    banner()
    print("Running Scan\n")
    print(cmd)
    print("\n" + "=" * 70 + "\n")

    warn_if_not_root(cmd)

    try:
        proc = subprocess.Popen(
            shlex.split(cmd),
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            bufsize=1,
        )

        for line in proc.stdout:
            print(line, end="")

        proc.wait()
        print(f"\n\n[+] Scan finished with exit code {proc.returncode}.")

    except KeyboardInterrupt:
        print("\n\n[!] Scan interrupted by user.")

    except Exception as e:
        print(f"\n[!] Error running scan: {e}")

    pause()


def show_last_command(last_cmd):
    clear()
    banner()
    print("Last Command\n")

    if last_cmd:
        print(last_cmd)
    else:
        print("No previous command yet.")

    pause()


def main():
    require_nmap()
    last_cmd = None

    while True:
        clear()
        banner()
        print("Main Menu\n")
        print("1) Build and run a new scan")
        print("2) Repeat last scan")
        print("3) Show last command")
        print("4) Quit")

        choice = input("\nSelect: ").strip().lower()

        if choice == "1":
            cmd = assemble_command()
            action = confirm_command(cmd)

            if action == "run":
                last_cmd = cmd
                run_command(cmd)
            elif action == "print":
                clear()
                banner()
                print("Dry Run Command\n")
                print(cmd)
                pause()

        elif choice == "2":
            if not last_cmd:
                print("\n[!] No previous command yet.")
                pause()
            else:
                run_command(last_cmd)

        elif choice == "3":
            show_last_command(last_cmd)

        elif choice == "4" or choice == "q":
            break

        else:
            print("\nInvalid choice.")
            pause()


if __name__ == "__main__":
    main()
